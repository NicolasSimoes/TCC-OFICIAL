# ============================================================
# Smart Sale Fortaleza — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com chaves reais.
# ============================================================

# Google Places API (opcional — enriquece dados de POIs)
# Obtenha em: https://console.cloud.google.com/
GOOGLE_API_KEY=sua_chave_google_aqui

# OpenAI API (opcional — geração de estratégia comercial via GPT-4o-mini)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Configuração do servidor FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
